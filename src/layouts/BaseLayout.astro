---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <title>{title || "Naskah Dinas"}</title>
  <style>
    @page {
      size: A4;
      margin: 2cm 2cm 2.5cm 3cm; /* Adjusted per Pasal 37: 2cm top (from logo), 2.5cm bottom, 3cm left, 2cm right */
    }
    body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      font-size: 12pt;
      line-height: 1.5;
      color: #000;
    }
    /* Hide UI elements when printing */
    @media print {
      .no-print { display: none; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
